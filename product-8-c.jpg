    <div class="a-section a-spacing-small a-spacing-top-small">  <table class="a-normal a-spacing-micro" role="list">  <tbody><tr class="a-spacing-small po-brand" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Brand Name</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">SAMODRA</span>   </td> </tr>  <tr class="a-spacing-small po-recommended_uses_for_product" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Recommended Uses For Product</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Bathroom</span>   </td> </tr>  <tr class="a-spacing-small po-mounting_type" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Mounting Type</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Seat Mount</span>   </td> </tr>  <tr class="a-spacing-small po-finish_type" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Finish Type</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Brass</span>   </td> </tr>  <tr class="a-spacing-small po-material" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Material</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Acrylonitrile Butadiene Styrene Brass Ceramic Stainless Steel</span>   </td> </tr>  <tr class="a-spacing-small po-color" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Color</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">C-black</span>   </td> </tr>  <tr class="a-spacing-small po-number_of_handles" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Number of Handles</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">1</span>   </td> </tr>  <tr class="a-spacing-small po-included_components" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Included Components</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Sprayer</span>   </td> </tr>  <tr class="a-spacing-small po-hole_count" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Hole Count</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">1</span>   </td> </tr>  <tr class="a-spacing-small po-special_feature" role="listitem"> <td class="a-span3" role="presentation">     <span class="a-size-base a-text-bold">Special Features</span>   </td> <td class="a-span9" role="presentation">    <span class="a-size-base po-break-word">Adjustable water spray, Dual Spout, Easy to install, Portable</span>   </td> </tr>    </tbody></table>  </div> </div> <div id="poToggleButton" class="a-expander-header a-expander-partial-collapse-header" style="opacity: 1; display: block;"><div class="a-expander-content-fade"></div><a href="javascript:void(0)" role="button" data-action="a-expander-toggle" class="a-declarative" data-a-expander-toggle="{&quot;allowLinkDefault&quot;:true, &quot;expand_prompt&quot;:&quot;See more&quot;, &quot;collapse_prompt&quot;:&quot;See less&quot;}"><i class="a-icon a-icon-extender-expand"></i><span class="a-expander-prompt">See more</span></a></div> </div>     </div>
