<div id="sp-cc-wrapper">









    



    
    
        <style>
            #cos-banner {
    background-color: #fff;
    border: 1px #ddd solid;
    bottom: 0;
    left: 0;
    margin: 0;
    padding: 60px 15%;
    position: fixed;
    right: 0;
    z-index: 1000;
    max-height: 100%;
    overflow-y: auto;
}

#cos-banner[disclosure-decision="daac"] {
    padding: 30px 15%;
}

.sp-cc-buttons {
    align-items: center;
    display: flex;
    flex-shrink: 0;
}

.sp-cc-buttons-container {
    position: sticky;
    bottom: -60px;
    background: #fff;
}

@media (max-height: 800px) {
    #cos-banner {
        padding: 2% 5%;
    }

    .sp-cc-text {
        max-height: 28vh;
        overflow-y: auto;
        flex-grow: 1;
    }

    .sp-cc-buttons-container {
        padding: 0.25rem 0rem;
    }
}

.sp-cc-buttons .a-declarative:nth-child(n+2) {
    margin-left: .385em;
}

.sp-cc-text {
    flex-grow: 1;
}

.sp-cc-text a {
    text-decoration: underline;
}
        </style>
    


